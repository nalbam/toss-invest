# Toss Invest Open API credentials (server-only — never expose to the client)
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
TOSS_ACCOUNT_SEQ=
TOSS_API_BASE=https://openapi.tossinvest.com

# Trading safety (see docs/dev-loop-prompt.md §6 — do not weaken)
# DRY_RUN defaults to true: real POST /orders is never sent unless explicitly disabled.
DRY_RUN=true
KILL_SWITCH=false

# Hard limits (fill in before enabling real orders)
MAX_ORDER_AMOUNT=
DAILY_LOSS_LIMIT=
