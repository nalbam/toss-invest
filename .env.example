# Toss Invest Open API credentials (server-only — never expose to the client)
TOSS_CLIENT_ID=""
TOSS_CLIENT_SECRET=""
TOSS_ACCOUNT_SEQ="1"
TOSS_API_BASE="https://openapi.tossinvest.com"

# Trading safety (see docs/dev-loop-prompt.md §6 — do not weaken)
# DRY_RUN defaults to true: real POST /orders is never sent unless explicitly disabled.
DRY_RUN=true
KILL_SWITCH=false

# Auto-trade activation (Phase 3). Defaults to false: the auto-executor only
# arms a real auto order when a human sets this to true (out-of-band approval).
# Even when true, every order still passes the §6 gate (DRY_RUN / limits / kill
# switch). An agent must never flip this itself.
AUTO_TRADE_ENABLED=false

# Hard limits (fill in before enabling real orders)
MAX_ORDER_AMOUNT=
DAILY_LOSS_LIMIT=

# AI advisor (Phase 4 — server-only, never exposed to the client). All optional:
# leave blank and the app boots normally; only the advisor path reports
# "not configured". LLM_PROVIDER selects the adapter; set the matching key.
LLM_PROVIDER=
LLM_MODEL=
OPENAI_API_KEY=
XAI_API_KEY=

# SQLite advice log (persistent record of every advisor run). Optional: defaults
# to ./data/advisor.db. The directory is created automatically.
ADVISOR_DB_PATH="data/advisor.db"
